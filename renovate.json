{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:recommended"],
    "labels": ["dependencies"],
    "platformAutomerge": true,
    "prHourlyLimit": 2,
    "prConcurrentLimit": 4,
    "schedule": ["before 5am on monday every 2 weeks"],
    "timezone": "Europe/Helsinki",
    "osvVulnerabilityAlerts": true,
    "vulnerabilityAlerts": {
        "schedule": ["at any time"],
        "labels": ["dependencies", "security"]
    },
    "packageRules": [
        {
            "description": "All npm patch and minor updates in one automerging PR",
            "matchManagers": ["npm"],
            "matchUpdateTypes": ["patch", "minor"],
            "groupName": "npm dependencies",
            "automerge": true,
            "automergeType": "pr",
            "automergeStrategy": "squash"
        },
        {
            "description": "npm major updates, grouped but require review",
            "matchManagers": ["npm"],
            "matchUpdateTypes": ["major"],
            "groupName": "npm major updates"
        },
        {
            "description": "CI/CD and Docker",
            "matchManagers": ["github-actions", "dockerfile", "docker-compose"],
            "groupName": "CI/CD and Docker"
        },
        {
            "description": "Directus major updates require migration review",
            "matchPackageNames": ["/^@directus\\\\//", "directus"],
            "matchUpdateTypes": ["major"],
            "groupName": "Directus major",
            "automerge": false
        },
        {
            "description": "PostgreSQL major, disabled",
            "matchManagers": ["dockerfile", "docker-compose"],
            "matchPackageNames": ["postgres"],
            "matchUpdateTypes": ["major"],
            "enabled": false
        },
        {
            "description": "Ignore icon libraries",
            "matchPackageNames": ["lucide-react", "react-icons"],
            "enabled": false
        }
    ]
}
